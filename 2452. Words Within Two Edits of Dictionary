class Solution {
    public List<String> twoEditWords(String[] queries, String[] dictionary) {
        
        List<String> ans = new ArrayList<>();

        for(String qstr : queries){

            for(String dstr : dictionary){

                int diff = 0;

                for(int i = 0; i < qstr.length(); i++){

                    if(qstr.charAt(i) != dstr.charAt(i)){
                        diff++;
                    }

                    if(diff > 2) break;
                }

                if(diff <= 2){
                    ans.add(qstr);
                    break;
                }
            }
        }

        return ans;
    }
}
